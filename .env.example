# Configuración de ejemplo del backend (análisis real, sin IA).
# Todas las variables son opcionales: si no se definen, se usan los valores por
# defecto seguros de app/config.py. Copia este fichero a `.env` en la raíz del
# repo; el backend lo carga al arrancar (sin sobrescribir variables ya exportadas).
# El `.env` no debe subirse al repositorio.

# --- Límites de subida ZIP ---
# Tamaño máximo del ZIP recibido (bytes). Por defecto ~20 MB.
TFG_ZIP_MAX_BYTES=20971520
# Número máximo de entradas dentro del ZIP (anti zip-bomb).
TFG_ZIP_MAX_ENTRIES=10000
# Tope de bytes al descomprimir el ZIP.
TFG_ZIP_MAX_UNCOMPRESSED_BYTES=104857600

# --- Clonado Git ---
# Activa/desactiva el modo git-clone (1/0).
TFG_ENABLE_GIT_CLONE=1
# Hosts HTTPS permitidos (lista separada por comas).
TFG_GIT_ALLOWED_HOSTS=github.com,gitlab.com
# Tiempo límite del git clone (segundos).
TFG_GIT_CLONE_TIMEOUT=180
# Longitud máxima de la URL de repositorio.
TFG_GIT_URL_MAX_LENGTH=2048

# --- Análisis por ruta local ---
# Activa/desactiva el modo ruta local (1/0). Activar solo en entornos controlados.
TFG_ENABLE_LOCAL_PATH=1
# Directorio raíz permitido para el modo ruta local (ruta absoluta).
# Si no se define, el modo queda deshabilitado.
TFG_LOCAL_ANALYSIS_ROOT=
# Longitud máxima de la ruta relativa solicitada.
TFG_LOCAL_PATH_MAX_LENGTH=4096

# --- Ejecución de Bandit/Semgrep ---
# Tiempo límite por subproceso (segundos). 0 = sin límite (solo entornos controlados).
TFG_ANALYSIS_TIMEOUT_SEC=600
# Límites previos al escaneo para árboles muy grandes.
TFG_ANALYSIS_MAX_FILES=20000
TFG_ANALYSIS_MAX_BYTES=314572800
# Directorios/globs a excluir (lista separada por comas).
# TFG_ANALYSIS_EXCLUDE_DIRS=.git,node_modules,__pycache__,.venv,venv,dist,build

# --- Capa IA (opcional, desactivada por defecto; ver ADR-003) ---
# Activa las explicaciones asistidas por IA (1/0).
TFG_AI_EXPLANATIONS_ENABLED=0
# Proveedor: stub (tests/demo offline), ollama (local recomendado) u openai (API opcional).
TFG_AI_PROVIDER=ollama
# Modelo a usar (Ollama o API).
TFG_AI_MODEL=llama3.2:3b
# Endpoint del servidor Ollama local.
TFG_AI_OLLAMA_URL=http://127.0.0.1:11434
# Timeout por llamada al modelo (segundos).
TFG_AI_TIMEOUT_SEC=30
# Incluir el snippet de código en el prompt (1/0). Desactivado por privacidad.
TFG_AI_INCLUDE_SNIPPET=0
# Clave de API, solo si TFG_AI_PROVIDER=openai (nunca subir a git).
OPENAI_API_KEY=
